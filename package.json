{
  "name": "@klausclaw18/openclaw-filebrowser",
  "version": "1.1.1",
  "description": "Read-only file browser plugin for OpenClaw Gateway.",
  "license": "MIT",
  "author": "klausclaw18",
  "homepage": "https://github.com/klausclaw18/openclaw-filebrowser",
  "repository": {
    "type": "git",
    "url": "https://github.com/klausclaw18/openclaw-filebrowser.git"
  },
  "bugs": {
    "url": "https://github.com/klausclaw18/openclaw-filebrowser/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "gateway",
    "file-browser",
    "read-only"
  ],
  "type": "module",
  "dependencies": {
    "typebox": "1.1.38"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.27"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.27"
    },
    "runtimeExtensions": [
      "./index.js"
    ]
  },
  "files": [
    "index.js",
    "gateway-paths.js",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "STATUS.md",
    "docs/**",
    "scripts/**"
  ]
}
